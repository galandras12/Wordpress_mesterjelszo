#: includes/class-mesterjelszo-admin.php:68
msgid "Ez a weboldal jelszóval védett. Kérjük, add meg a hozzáférési jelszót a tartalom megtekintéséhez."
msgstr "This website is password protected. Please enter the access password to view the content."

#: includes/class-mesterjelszo-admin.php:112
msgid "Mesterjelszo beállítások"
msgstr "Master Password Settings"

#: includes/class-mesterjelszo-admin.php:113
msgid "Mesterjelszo"
msgstr "Master Password"

#: includes/class-mesterjelszo-admin.php:133
msgid "Beállítások"
msgstr "Settings"

#: includes/class-mesterjelszo-admin.php:243
msgid "A mesterjelszo sikeresen frissítve lett."
msgstr "Master password has been successfully updated."

#: includes/class-mesterjelszo-admin.php:250
msgid "A megadott két jelszó nem egyezik meg, ezért a mesterjelszo nem került frissítésre. A többi beállítás elmentésre került."
msgstr "The two passwords do not match, so the master password was not updated. Other settings have been saved."

#: includes/class-mesterjelszo-admin.php:283
msgid "A Mesterjelszo bővítmény be van kapcsolva, de még nincs mesterjelszo beállítva - a weboldal jelenleg NEM védett."
msgstr "The Master Password plugin is enabled, but no master password has been set - the website is currently NOT protected."

#: includes/class-mesterjelszo-admin.php:287
msgid "Beállítás most"
msgstr "Configure Now"

#: includes/class-mesterjelszo-admin.php:327
msgid "Kép kiválasztása"
msgstr "Select Image"

#: includes/class-mesterjelszo-admin.php:328
msgid "Kiválasztás"
msgstr "Select"

#: includes/class-mesterjelszo-admin.php:329
msgid "Biztosan eltávolítod a képet?"
msgstr "Are you sure you want to remove the image?"

#: includes/class-mesterjelszo-admin.php:330
msgid "A két jelszó nem egyezik meg."
msgstr "The two passwords do not match."

#: includes/class-mesterjelszo-admin.php:331
msgid "A jelszónak legalább 6 karakter hosszúnak kell lennie."
msgstr "The password must be at least 6 characters long."

#: includes/class-mesterjelszo-admin.php:344
msgid "Nincs jogosultságod ehhez az oldalhoz."
msgstr "You do not have permission to access this page."

#: includes/class-mesterjelszo-public.php:117
msgid "Hozzáférés megtagadva: a weboldal jelszóval védett."
msgstr "Access denied: the website is password protected."

#: includes/class-mesterjelszo-public.php:178
msgid "A weboldal jelszóval védett. A REST API jelenleg nem elérhető."
msgstr "The website is password protected. The REST API is currently unavailable."

#: includes/class-mesterjelszo-public.php:197
#, php-format
msgid "Túl sok sikertelen próbálkozás történt. Kérjük, próbáld újra kb. %d perc múlva."
msgstr "Too many failed attempts. Please try again in approximately %d minutes."

#: includes/class-mesterjelszo-public.php:210
msgid "Kérjük, add meg a jelszót."
msgstr "Please enter the password."

#: includes/class-mesterjelszo-public.php:226
msgid "Hibás jelszó. Kérjük, próbáld újra."
msgstr "Incorrect password. Please try again."

#: mesterjelszo.php:56
msgid "A Mesterjelszo bővítmény működéséhez legalább PHP 8.0 verzió szükséges. Kérjük, egyeztess a tárhelyszolgáltatóddal a PHP verzió frissítéséről."
msgstr "The Master Password plugin requires at least PHP version 8.0. Please contact your hosting provider to upgrade your PHP version."
